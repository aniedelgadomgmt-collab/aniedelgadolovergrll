        <a href="#release" class="btn-ghost">Press Release</a>
      </div>
    </div>
  </div>
</div>

<!-- ── LISTEN ── -->
<div id="listen" class="listen-wrap">
  <span class="eyebrow" style="display:block; margin-bottom:12px;">Exclusive Preview</span>
  <h2 style="font-family:'Playfair Display',serif; font-size:clamp(28px,4vw,44px); font-weight:700; margin-bottom:8px;">Hear the Track</h2>
  <p style="color:var(--gray); font-size:14px;">For press & media — embargoed until June 18, 2026</p>
  <div class="listen-player">
    <a href="https://www.dropbox.com/scl/fi/kipg4gvwzt4gkrhnqg4q5/Anie-Delgado-LOVERGRLL-MASTER.wav?rlkey=lq7hj7rkctf3ox2jyd21iiw5e&st=ewbedx8w&dl=0" target="_blank" rel="noopener" style="text-decoration:none;">
      <div class="play-btn"></div>
